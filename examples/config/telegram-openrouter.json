{
  "version": 2,
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "model_name": "openrouter-glm-5v",
      "max_tokens": 8192,
      "context_window": 131072,
      "temperature": 0.7,
      "max_tool_iterations": 20,
      "summarize_message_threshold": 20,
      "summarize_token_percent": 75
    }
  },
  "model_list": [
    {
      "model_name": "openrouter-glm-5v",
      "model": "openrouter/z-ai/glm-5v-turbo",
      "api_key": "env://OPENROUTER_API_KEY"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "env://TELEGRAM_BOT_TOKEN",
      "allow_from": ["telegram:YOUR_TELEGRAM_USER_ID"],
      "group_trigger": {
        "mention_only": true
      },
      "streaming": {
        "enabled": true
      }
    }
  },
  "email_channel": {
    "enabled": false
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18800,
    "log_level": "info"
  },
  "tools": {
    "exec": {
      "enabled": true
    },
    "web_search": {
      "enabled": false
    },
    "vision": {
      "enabled": true,
      "model": "openrouter/z-ai/glm-5v-turbo",
      "api_key": "env://OPENROUTER_API_KEY",
      "prompt": "Describe this image in detail."
    },
    "media_cleanup": {
      "enabled": true,
      "max_age": 30,
      "interval": 5
    },
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_dir": {
      "enabled": true
    }
  }
}
