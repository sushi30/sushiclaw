{
  "version": 2,
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "model_name": "claude-sonnet",
      "max_tokens": 8192,
      "context_window": 131072,
      "temperature": 0.7,
      "max_tool_iterations": 20,
      "summarize_message_threshold": 20,
      "summarize_token_percent": 75
    }
  },
  "model_list": [
    {
      "model_name": "claude-sonnet",
      "model": "anthropic/claude-sonnet-4-6",
      "api_key": "env://ANTHROPIC_API_KEY",
      "api_base": "https://api.anthropic.com/v1"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allow_from": [],
      "group_trigger": {
        "mention_only": true
      },
      "reasoning_channel_id": "",
      "streaming": {
        "enabled": true
      }
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18800,
    "log_level": "info"
  },
  "tools": {
    "exec": {
      "enabled": true
    },
    "web_search": {
      "enabled": true,
      "provider": "duckduckgo",
      "max_results": 5,
      "duckduckgo": {
        "enabled": true
      }
    },
    "media_cleanup": {
      "enabled": true,
      "max_age": 30,
      "interval": 5
    }
  }
}
